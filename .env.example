# --- LICENSE ---
# License key issued to your account. The application does not start it without it
LICENSE_KEY=

# --- GENERAL SETTINGS ---
# --- CODE INDEXING & DOCLING ---
CODE_INDEX_ENABLED=true
# Optional: override the default languages - Supported: "csharp", "typescript", "javascript", "java".
# CODE_INDEX_LANGUAGES=csharp,typescript
# Optional: override the default exclude glob patterns
# CODE_INDEX_EXCLUDE_PATTERNS=**/bin/**,**/node_modules/**,**/obj/**,**/.git/**,**/Lib/**

# Host path for code indexing (e.g., /c/git/my-project)
HOST_CODE_PATH=/c/git/my-project

# --- JIRA & CONFLUENCE ---
JIRA_ENABLED=false
JIRA_BASE_URL=https://my-project.atlassian.net/
JIRA_EMAIL=
JIRA_API_TOKEN=
# Comma-separated Jira project keys (e.g. PROJ1,PROJ2)
JIRA_PROJECT_KEYS=
JIRA_PAGE_SIZE=50

CONFLUENCE_ENABLED=false
CONFLUENCE_BASE_URL=https://my-project.atlassian.net/wiki
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
# Comma-separated Confluence space keys (e.g. P2F,DOCS)
CONFLUENCE_SPACE_KEYS=

# --- CLICKUP ---
CLICKUP_ENABLED=false
CLICKUP_API_TOKEN=
# Comma-separated ClickUp team / workspace IDs (eg. 90151291983,90151291984)
CLICKUP_TEAM_IDS=
CLICKUP_PAGE_SIZE=100

CLICKUP_DOCS_ENABLED=false
CLICKUP_DOCS_PAGE_SIZE=50

# --- AZURE DEVOPS (ADO) ---
ADO_PAT=
ADO_ORG=myproject
# Comma-separated ADO project names (e.g. TC,TC2)
ADO_PROJECTS=

ADO_WORKITEM_ENABLED=false
# Optional: override the default work item types
# ADO_WORKITEM_TYPES=Bug,User Story,Task,Feature,Epic
ADO_WORKITEM_PAGE_SIZE=200

ADO_WIKI_ENABLED=true
ADO_WIKI_PAGE_SIZE=100

ADO_PR_ENABLED=false
# Comma-separated project/repo slugs (e.g. MP/Repo1,MP/Repo2)
ADO_PR_REPOS=
ADO_PR_PAGE_SIZE=100

# --- GOOGLE DRIVE ---
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_SERVICEACCOUNT_KEY_PATH=
GOOGLE_DRIVE_DRIVE_ID=
# Comma-separated Drive folder IDs
GOOGLE_DRIVE_FOLDER_IDS=
# Optional: override the default supported MIME types
# GOOGLE_DRIVE_SUPPORTED_MIME_TYPES=application/vnd.google-apps.document,application/vnd.google-apps.spreadsheet,application/vnd.google-apps.presentation,text/plain,text/markdown,text/html,application/pdf
GOOGLE_DRIVE_PAGE_SIZE=100

# --- GITHUB ---
GITHUB_ENABLED=false
GITHUB_TOKEN=
# Comma-separated owner/repo slugs (e.g. myorg/backend,myorg/frontend)
GITHUB_REPOS=



DOCLING_ENABLED=true
DOCLING_TIMEOUT=120
DOCLING_MAX_DOCUMENT_SIZE_IN_BYTES=50000000

# Grafana settings
GF_ANONYMOUS=false
GRAFANA_PASSWORD=admin

# --- INFRASTRUCTURE ---
# These settings are fine with defaults

# Neo4j password
NEO4J_PASSWORD=adam-dev
NEO4J_DATABASE=neo4j

# --- VECTOR & EMBEDDINGS ---
# Qdrant configuration
QDRANT_VECTOR_DIMENSIONS=384
QDRANT_HNSW_M=16
QDRANT_EF_CONSTRUCT=200
ENABLE_QUANTIZATION=false
UPSERT_BATCH_SIZE=200

# Embedding Provider (Ollama, AzureOpenAI, etc.)
EMBEDDING_PROVIDER=Ollama
EMBEDDING_MODEL=all-minilm
EMBEDDING_DIMENSIONS=384
EMBEDDING_BATCHSIZE=50

# --- MCP SERVER ---
MCP_CLIENT_SECRET=ZKGXHWBYPRLGAOIE

